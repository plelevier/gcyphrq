{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "src",
    "strict": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true
  },
  "include": ["src/lib.ts", "src/lib-types.ts", "src/graph.ts", "src/types/cypher.ts", "src/types/antlr4.d.ts", "src/engine/cypher-parser.ts", "src/engine/cypher-engine.ts"],
  "exclude": ["test"]
}
